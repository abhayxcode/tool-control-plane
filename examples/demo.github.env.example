# Copy to a private env file before use, then set:
# MAJDOOR_DEMO_ENV_FILE=tool-control-plane/examples/demo.github.env ./scripts/run-local-demo.sh
#
# Required for real GitHub-backed code, CI, and deployment tool calls.
TOOL_CONTROL_PLANE_CODE_PROVIDER=github
TOOL_CONTROL_PLANE_DEPLOY_PROVIDER=github
GITHUB_TOKEN=ghp_replace_with_fine_grained_or_app_token

# Optional. Leave empty for github.com.
GITHUB_API_BASE_URL=

# Optional local hardening.
TOOL_CONTROL_PLANE_RATE_LIMIT_PER_MINUTE=120
TOOL_CONTROL_PLANE_STORE=sqlite
TOOL_CONTROL_PLANE_SQLITE_PATH=.doc/demo-controlplane.sqlite3
