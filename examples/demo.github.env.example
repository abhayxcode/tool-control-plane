# Copy to a private env file before use, then set:
# MAJDOOR_DEMO_ENV_FILE=tool-control-plane/examples/demo.github.env ./scripts/run-local-demo.sh
#
# Required for real GitHub-backed code, CI, and deployment tool calls.
# The token/App installation must be scoped to the demo repo and allow:
# - contents read/write for branch and file updates
# - pull requests read/write for draft PR creation/update
# - actions/checks read for CI and deployment workflow inspection
# - metadata read
TOOL_CONTROL_PLANE_CODE_PROVIDER=github
TOOL_CONTROL_PLANE_DEPLOY_PROVIDER=github

# Option A: fine-grained PAT or pre-minted installation token.
GITHUB_TOKEN=ghp_replace_with_fine_grained_or_app_token

# Option B: GitHub App installation auth. Leave GITHUB_TOKEN empty when using this.
# GITHUB_APP_ID=12345
# GITHUB_APP_INSTALLATION_ID=67890
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem
# Or set GITHUB_APP_PRIVATE_KEY with literal \n escapes in a private env file.

# Optional. Leave empty for github.com.
GITHUB_API_BASE_URL=

# Optional but recommended for real-demo preflight. Set to the pushed demo repo.
TOOL_CONTROL_PLANE_DEMO_REPOSITORY=majdoor-demo/backend

# Optional local hardening.
TOOL_CONTROL_PLANE_RATE_LIMIT_PER_MINUTE=120
TOOL_CONTROL_PLANE_STORE=sqlite
TOOL_CONTROL_PLANE_SQLITE_PATH=.doc/demo-controlplane.sqlite3

# Optional. Route live error evidence through Sentry.
# Requires a Sentry token with event:read access to the selected project.
# TOOL_CONTROL_PLANE_ERRORS_PROVIDER=sentry
# SENTRY_AUTH_TOKEN=sntrys_replace_with_event_read_token
# SENTRY_ORG=acme
# SENTRY_PROJECT=backend
# SENTRY_BASE_URL=

# Optional. Route live service-health metrics through Prometheus.
# TOOL_CONTROL_PLANE_METRICS_PROVIDER=prometheus
# PROMETHEUS_BASE_URL=http://localhost:9090
# PROMETHEUS_BEARER_TOKEN=
# PROMETHEUS_SERVICE_LABEL=service
# PROMETHEUS_ENVIRONMENT_LABEL=environment
# PROMETHEUS_STATUS_LABEL=status

# Optional. Route live runtime evidence through Kubernetes.
# kubectl proxy users can set KUBERNETES_BASE_URL=http://localhost:8001 without a bearer token.
# TOOL_CONTROL_PLANE_RUNTIME_PROVIDER=kubernetes
# KUBERNETES_BASE_URL=http://localhost:8001
# KUBERNETES_BEARER_TOKEN=
# KUBERNETES_NAMESPACE=prod
# KUBERNETES_LABEL_SELECTOR=app=backend-api
# KUBERNETES_SERVICE_LABEL=app
# KUBERNETES_ENVIRONMENT_LABEL=environment
